      "source": [
        "# =====================================================================\n",
        "# Corrected evaluation cell — metrics computed on the REAL price scale\n",
        "# This REPLACES the old cell that printed R2 = -14.39\n",
        "# (the one starting with: import numpy as np / from sklearn.metrics ...)\n",
        "# After pasting -> Runtime -> Run all\n",
        "# =====================================================================\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
        "\n",
        "LOOKBACK = 60  # must match the window used in training\n",
        "\n",
        "# Rebuild the test windows consistently (60-day look-back)\n",
        "test_data = scaled_data[training_data_len - LOOKBACK:]\n",
        "\n",
        "X_test = []\n",
        "for i in range(LOOKBACK, len(test_data)):\n",
        "    X_test.append(test_data[i - LOOKBACK:i, 0])\n",
        "X_test = np.array(X_test)\n",
        "X_test = np.reshape(X_test, (X_test.shape[0], X_test.shape[1], 1))\n",
        "\n",
        "# The model outputs values in SCALED space -> bring them back to real prices\n",
        "pred_scaled = model.predict(X_test)\n",
        "pred_real = scaler.inverse_transform(pred_scaled).flatten()\n",
        "\n",
        "# Ground truth on the SAME scale: real, unscaled close prices\n",
        "y_true_real = dataset[training_data_len:].flatten()\n",
        "\n",
        "# Both arrays are now in real currency units -> metrics are meaningful\n",
        "mae  = mean_absolute_error(y_true_real, pred_real)\n",
        "mse  = mean_squared_error(y_true_real, pred_real)\n",
        "rmse = np.sqrt(mse)\n",
        "mape = np.mean(np.abs((y_true_real - pred_real) / y_true_real)) * 100\n",
        "r2   = r2_score(y_true_real, pred_real)\n",
        "\n",
        "print(\"LSTM Metrics (real price scale):\")\n",
        "print(f\"MAE  = {mae:.2f}\")\n",
        "print(f\"RMSE = {rmse:.2f}\")\n",
        "print(f\"MAPE = {mape:.2f}%\")\n",
        "print(f\"R2   = {r2:.4f}\")\n",
        "\n",
        "# Learning curve (kept from your original cell)\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.plot(training.history['loss'], label='Train Loss')\n",
        "plt.title('Learning Curve (training)')\n",
        "plt.xlabel('Epochs')\n",
        "plt.ylabel('Loss')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "# Optional future improvement: fit the scaler on the TRAINING data only\n",
        "# (scaler.fit(train) then .transform) to avoid leaking test info into scaling."
