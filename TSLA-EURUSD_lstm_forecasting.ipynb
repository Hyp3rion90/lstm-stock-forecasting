      "cell_type": "code",
      "source": [
        "#Preparo i dati per il modello LSTM\n",
        "stock_close = data['Close']\n",
        "\n",
        "dataset = stock_close.values #converte in un array di nunpy\n",
        "\n",
        "training_data_len = int(np.ceil(len(dataset)*0.8))\n",
        "\n",
        "# --- Dati raw (non scalati) per i modelli classici ---\n",
        "close_raw = dataset.reshape(-1)\n",
        "\n",
        "train_close_raw = close_raw[:training_data_len]\n",
        "test_close_raw  = close_raw[training_data_len:]\n",
        "\n",
        "scaler = StandardScaler()\n",
        "scaled_data = scaler.fit_transform(dataset.reshape(-1, 1))\n",
        "\n",
        "training_data = scaled_data[:training_data_len] #80% dei dati\n",
        "\n",
        "x_train , y_train = [] , []  #X tutte le features Y prezzi di chiusura\n",
        "\n",
        "\n",
        "#creo una finestra di dati di 60gg\n",
        "for i in range(60, len(training_data)):\n",
        "    x_train.append(training_data[i-60:i,0])\n",
        "    y_train.append(training_data[i,0])\n",
        "\n",
        "x_train,y_train = np.array(x_train), np.array(y_train)\n",
        "x_train =np.reshape(x_train,(x_train.shape[0],x_train.shape[1],1))"
      ],
      "metadata": {
        "collapsed": true,
        "id": "B56Ljhn8mHZi"
      },
      "execution_count": 12,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#costruiscxo il modello\n",
        "model = keras.models.Sequential()\n",
        "\n",
        "#1 layer\n",
        "model.add(keras.layers.LSTM(128, return_sequences = True, input_shape = (x_train.shape[1],1)))\n",
        "model.add(keras.layers.Dropout(0.2))\n",
        "\n",
        "#2 layer\n",
        "model.add(keras.layers.LSTM(64, return_sequences = False))\n",
        "\n",
        "#3 layer (Dense)\n",
        "model.add(keras.layers.Dense(64,activation='relu'))\n",
        "\n",
        "#4 layer (Dropout)\n",
        "model.add(keras.layers.Dropout(0.5))\n",
        "\n",
        "#Final output layer\n",
        "model.add(keras.layers.Dense(1))\n",
